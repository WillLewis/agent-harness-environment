{
  "name": "agent-harness-environment",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "pnpm --filter @ahe/web dev",
    "build": "pnpm --filter @ahe/web build",
    "preview": "pnpm --filter @ahe/web preview",
    "deploy:check": "python scripts/check_deployment_readiness.py",
    "smoke:hosted": "python scripts/smoke_hosted_demo.py",
    "smoke:hosted:local": "python scripts/smoke_hosted_demo.py --url http://localhost:3000",
    "lint": "pnpm --filter @ahe/web lint",
    "typecheck": "pnpm --filter @ahe/web typecheck",
    "test": "python -m pytest",
    "repo:status": "python scripts/repo_status.py",
    "validate:fixtures": "python scripts/validate_fixtures.py",
    "eval": "python packages/evals/run_eval.py data/traces/guarded_recovery_date_parser.json",
    "eval:baseline": "python packages/evals/run_eval.py data/traces/baseline_date_parser.json",
    "eval:suite": "python packages/evals/run_suite.py --report table",
    "eval:ci": "python packages/evals/run_suite.py --ci",
    "eval:audit": "python packages/evals/audit_metric_drift.py",
    "compare": "python packages/evals/policy_compare.py data/evals/policy_comparison.json",
    "runner:batch": "python services/runner/run_batch.py",
    "runner:batch:promote": "python services/runner/run_batch.py --promote-candidates",
    "router": "python packages/reward/bandit_router.py",
    "router:decision": "python packages/reward/bandit_router.py",
    "router:train": "python packages/reward/train_router.py",
    "router:export-fixture": "python packages/reward/export_router_fixture.py",
    "export:braintrust:dry-run": "python packages/evals/adapters/braintrust_adapter.py --dry-run",
    "export:braintrust:live": "python packages/evals/adapters/braintrust_adapter.py --live",
    "export:weave:dry-run": "python packages/evals/adapters/weave_adapter.py --dry-run",
    "export:weave:live": "python packages/evals/adapters/weave_adapter.py --live",
    "observe": "python packages/evals/observability.py --pretty",
    "observe:dry-run": "python packages/evals/observability.py --dry-run --pretty",
    "router:fixture": "python packages/reward/bandit_router.py data/router_decisions.json",
    "build:harness": "AHE_DEPLOY_TARGET=cloudflare AHE_PUBLIC_BASE_PATH=/agent-harness pnpm --filter @ahe/web build",
    "preview:harness": "wrangler dev --config wrangler.harness.jsonc --local --port 8787",
    "deploy:harness": "wrangler deploy --config wrangler.harness.jsonc",
    "ship:harness": "pnpm build:harness && pnpm deploy:harness"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2",
    "wrangler": "^4"
  }
}
