# Optional. The starter works without any of these keys.
#
# Observability (Phase 13b) is OFF by default. The hosted webapp is always
# static and never reads these — they only affect the local runner/eval
# observability export (packages/evals/observability.py).
#
# AHE_OBSERVABILITY: off | braintrust | wandb | both
AHE_OBSERVABILITY=off

# Braintrust (https://www.braintrust.dev) — optional live experiment logging.
BRAINTRUST_API_KEY=
BRAINTRUST_PROJECT=

# Weights & Biases (https://wandb.ai) — optional live run tracking.
# WANDB_MODE: online | offline | disabled (offline/disabled need no API key).
WANDB_API_KEY=
WANDB_PROJECT=
WANDB_ENTITY=
WANDB_MODE=online

# Unrelated optional key (not required for the starter).
OPENAI_API_KEY=
